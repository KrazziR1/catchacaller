{
  "name": "BusinessProfile",
  "type": "object",
  "properties": {
    "business_name": {
      "type": "string"
    },
    "industry": {
      "type": "string",
      "enum": [
        "general",
        "hvac",
        "plumbing",
        "roofing",
        "med_spa",
        "legal",
        "hospitality",
        "marketing",
        "real_estate",
        "dental",
        "fitness",
        "automotive"
      ],
      "default": "general"
    },
    "phone_number": {
      "type": "string",
      "description": "Business phone number to monitor"
    },
    "twilio_number_sid": {
      "type": "string",
      "description": "Twilio SID for the provisioned phone number"
    },
    "booking_url": {
      "type": "string",
      "description": "Calendly or booking link"
    },
    "website": {
      "type": "string"
    },
    "timezone": {
      "type": "string",
      "default": "America/New_York"
    },
    "business_hours": {
      "type": "string",
      "description": "Business hours description"
    },
    "auto_response_enabled": {
      "type": "boolean",
      "default": true
    },
    "ai_personality": {
      "type": "string",
      "enum": [
        "professional",
        "friendly"
      ],
      "default": "friendly"
    },
    "average_job_value": {
      "type": "number",
      "default": 500,
      "description": "Average revenue per job for ROI calculations"
    }
  },
  "required": [
    "business_name"
  ]
}