{
  "name": "OnboardingProgress",
  "type": "object",
  "properties": {
    "user_email": {
      "type": "string"
    },
    "completed_steps": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "List of completed step keys"
    },
    "current_step": {
      "type": "number",
      "default": 0
    },
    "is_complete": {
      "type": "boolean",
      "default": false
    }
  },
  "required": [
    "user_email"
  ]
}