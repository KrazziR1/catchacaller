{
  "name": "LeadConsent",
  "type": "object",
  "properties": {
    "phone_number": {
      "type": "string",
      "description": "Lead's phone number (E.164 format)"
    },
    "called_at": {
      "type": "string",
      "format": "date-time",
      "description": "When the lead called the business"
    },
    "consent_type": {
      "type": "string",
      "enum": [
        "called_business"
      ],
      "default": "called_business",
      "description": "How consent was established"
    },
    "caller_state": {
      "type": "string",
      "description": "US state of the caller (2-letter code)"
    },
    "ebs_expiration_date": {
      "type": "string",
      "format": "date-time",
      "description": "When the established business relationship expires (90 days from call)"
    },
    "explicit_sms_consent": {
      "type": "boolean",
      "default": false,
      "description": "Whether caller has explicitly confirmed SMS consent (required for CA/NY)"
    },
    "explicit_consent_at": {
      "type": "string",
      "format": "date-time",
      "description": "When explicit SMS consent was confirmed"
    },
    "is_valid": {
      "type": "boolean",
      "default": true,
      "description": "Whether consent is still valid (not revoked)"
    },
    "conversation_id": {
      "type": "string",
      "description": "Reference to the associated conversation"
    }
  },
  "required": [
    "phone_number",
    "called_at",
    "consent_type"
  ]
}